---
import SectionHeading from '../components/SectionHeading/SectionHeading.astro';
import { GitHubIcon } from '../components/icons/GitHubIcon';
import { LinkedInIcon } from '../components/icons/LinkedInIcon';
import { MailIcon } from '../components/icons/MailIcon';
import { personal } from '../data/personal';
---

<section id="contact" class="section contact">
  <div class="container">
    <SectionHeading line1="LET'S WORK" line2="TOGETHER" align="center" />

    <p class="sub">
      I'm currently open to new opportunities. Whether you have a role in mind or just want to say
      hi — my inbox is always open.
    </p>

    <a href={`mailto:${personal.email}`} class="email-link">
      {personal.email}
    </a>

    <div class="link-cards">
      <a href={`mailto:${personal.email}`} class="link-card">
        <MailIcon size={24} />
        <span class="link-label">Email</span>
        <span class="link-value">{personal.email}</span>
      </a>

      <a href={personal.github} target="_blank" rel="noopener noreferrer" class="link-card">
        <GitHubIcon size={24} />
        <span class="link-label">GitHub</span>
        <span class="link-value">github.com/jf423</span>
      </a>

      <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="link-card">
        <LinkedInIcon size={24} />
        <span class="link-label">LinkedIn</span>
        <span class="link-value">jeffwangtw</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-24);
    text-align: center;
  }

  .sub {
    font-size: var(--font-size-lg);
    color: var(--color-text-2);
    max-width: 520px;
    margin-inline: auto;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .email-link {
    display: inline-block;
    font-size: clamp(var(--font-size-xl), 3vw, var(--font-size-4xl));
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-accent);
    margin-bottom: var(--space-12);
    transition: opacity var(--transition-fast);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 6px;
  }

  .email-link:hover {
    text-decoration-color: var(--color-accent);
    opacity: 0.85;
  }

  .link-cards {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    color: var(--color-text-2);
    min-width: 160px;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .link-card:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface-2);
    color: var(--color-text-1);
    transform: translateY(-3px);
  }

  .link-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-3);
  }

  .link-value {
    font-size: var(--font-size-sm);
    font-weight: 500;
  }

  @media (max-width: 639px) {
    .link-cards {
      flex-direction: column;
      align-items: stretch;
    }

    .link-card {
      flex-direction: row;
      justify-content: flex-start;
      min-width: unset;
      gap: 1rem;
      padding: 1.25rem;
    }

    .link-label {
      display: none;
    }
  }
</style>
