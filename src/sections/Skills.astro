---
import SectionHeading from '../components/SectionHeading/SectionHeading.astro';
import SkillBadge from '../components/SkillBadge/SkillBadge.astro';
import { skillGroups } from '../data/skills';
---

<section id="skills" class="section skills">
  <div class="container">
    <SectionHeading line1="MY" line2="SKILLS" />

    <div class="groups">
      {
        skillGroups.map((group) => (
          <div class="group">
            <h3 class="category">{group.category}</h3>
            <div class="skill-grid">
              {group.skills.map((skill) => (
                <SkillBadge skill={skill} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills {
    padding-block: var(--space-24);
  }

  .groups {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-8);
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .category {
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: var(--space-2);
  }

  @media (max-width: 639px) {
    .groups {
      grid-template-columns: 1fr;
    }
  }
</style>
