---
import ProfileCard from '../components/ProfileCard/ProfileCard.astro';
import StatChip from '../components/StatChip/StatChip.astro';
import { personal } from '../data/personal';
---

<section id="hero" class="hero">
  <div class="container">
    <div class="hero-grid">

      <div class="hero-left">
        <div class="heading-wrap">
          <h2 class="heading">
            JEFF<br />WANG
          </h2>
          <span class="heading-ghost" aria-hidden="true">JEFF WANG</span>
        </div>

        <p class="tagline">{personal.tagline}</p>

        <div class="stats">
          {personal.stats.map((stat) => <StatChip value={stat.value} label={stat.label} />)}
        </div>

        <div class="ctas">
          <a
            href={personal.resumeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            View Resume ↗
          </a>
          <button
            class="btn btn-ghost"
            onclick="document.getElementById('contact')?.scrollIntoView({behavior:'smooth'})"
          >
            Contact Me
          </button>
        </div>
      </div>

      <div class="hero-right">
        <div class="profile-glow" aria-hidden="true"></div>
        <ProfileCard />
        <span class="availability">
          <span class="dot" aria-hidden="true"></span>
          Open to Work
        </span>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    padding-bottom: var(--space-16);
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    width: 100%;
  }

  /* ── Two-column grid ─────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: center;
  }

  /* ── Left: text content ──────────────────────────── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .heading-wrap {
    position: relative;
    display: inline-block;
    overflow: hidden;
  }

  .heading {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-text-1);
    position: relative;
    z-index: 1;
  }

  .heading-ghost {
    position: absolute;
    font-size: clamp(5rem, 16vw, 11rem);
    font-weight: 800;
    color: var(--color-text-1);
    opacity: 0.04;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .tagline {
    font-size: clamp(var(--font-size-base), 2vw, var(--font-size-lg));
    color: var(--color-text-2);
    max-width: 520px;
    line-height: 1.7;
  }

  .stats {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Right: profile ──────────────────────────────── */
  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    position: relative;
  }

  .profile-glow {
    position: absolute;
    inset: -40px;
    background: radial-gradient(ellipse at center, rgba(129, 140, 248, 0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    border-radius: 50%;
  }

  .hero-right :global(.card) {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .availability {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: var(--radius-full);
    padding: 0.35rem 0.875rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Buttons ─────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-base);
    font-size: var(--font-size-base);
    font-weight: 600;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
    cursor: pointer;
    font-family: var(--font-sans);
    border: none;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-h);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text-1);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-border-hover);
    background: var(--color-surface);
  }

  /* ── Mobile: single column ───────────────────────── */
  @media (max-width: 767px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .hero-right {
      order: -1;
      align-items: flex-start;
    }

    .heading-ghost {
      display: none;
    }

    .stats {
      gap: var(--space-3);
    }

    .ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
